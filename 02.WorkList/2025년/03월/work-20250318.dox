adb shell am broadcast -a android.intent.action.GLOBAL_BUTTON -n com.kaon.lowbettery/.ButtonListenerService

adb shell am broadcast -a android.intent.action.GLOBAL_BUTTON -p com.cisco.epg.cjh.android

adb shell am broadcast -a com.kaon.lowbettery.ACTION_LOW_BATTERY -p com.cisco.epg.cjh.android




adb shell am broadcast -a android.intent.action.RCU_LOW_BATTERY -n com.kaonmedia.kaonmanagerservice/.RcuLowBatteryReceiver







