        if (!down) {
            /* Start RCU find me */
            if (DEBUG_INPUT) Log.d(TAG, "send find-me key");

            // 기존 리모콘 찾기 동작
            Intent pairintent = new Intent("kaon.android.intent.action.FIND_ME");
            if (DEBUG_INPUT) Log.d(TAG, "intent: " + pairintent);
            mContext.sendBroadcastAsUser(pairintent, UserHandle.ALL);

            // ★ 데이터플랫폼 로그용 브로드캐스트
            Intent logIntent =
                    new Intent("kaon.android.intent.action.STB_EVENT_RCU_FIND");
            logIntent.putExtra("keyCode", keyCode);
            if (inputdevice != null) {
                logIntent.putExtra("deviceName", inputdevice.getName());
            }
            mContext.sendBroadcastAsUser(logIntent, UserHandle.ALL);
        }
    }
    ...
}

2. KaonManagerService – 브로드캐스트 리시버
2-1. RcuFindEventReceiver.java (새 파일)
경로(예시)
// Z:\K1200_ATV14\lghv_k1200ua\vendor\kaon\K1200UA\kaonsrc\apps\KaonDeviceManager\src\com\lghv\atv\iptv\fw\dmsvc\RcuFindEventReceiver.java

package com.lghv.atv.iptv.fw.dmsvc;

import android.content.BroadcastReceiver;
import android.content.Context;
import android.content.Intent;
import android.util.Log;

/**
 * 리모콘 찾기(F1) 브로드캐스트 수신 → DP 서버로 전송 트리거
 */
public class RcuFindEventReceiver extends BroadcastReceiver {

    private static final String TAG = "RcuFindEventReceiver";
    private static final String ACTION_RCU_FIND =
            "kaon.android.intent.action.STB_EVENT_RCU_FIND";

    @Override
    public void onReceive(Context context, Intent intent) {
        if (!ACTION_RCU_FIND.equals(intent.getAction())) {
            return;
        }

        int keyCode = intent.getIntExtra("keyCode", -1);
        String deviceName = intent.getStringExtra("deviceName");

        Log.d(TAG, "RCU find-me key pressed. keyCode=" + keyCode
                + ", deviceName=" + deviceName);

        // IPTV 모델용: 리모콘 찾기 이벤트 하나만 전송
        new Post();   // 아래 Post.java
    }
}



