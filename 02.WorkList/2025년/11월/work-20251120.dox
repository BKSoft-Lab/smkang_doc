Log.i(TAG,"NETWORK_TYPE: "+(networkType.equals(NETWORK_TYPE_LGHV)?"LGHV":"LGU+"));
Log.i(TAG,"SEND_GLOBALKEY: startForegroundService(lghv_intent)");
context.startForegroundService(lghv_intent);
