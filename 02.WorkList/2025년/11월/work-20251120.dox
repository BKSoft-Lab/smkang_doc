	private void stopOTTAppByForce(Context context) {
Log.d(TAG,"stopOTTAppByForce .... ####");
String topActivityName = null;
String stopCmd = null;

topActivityName = getTopActivityName(context);

// set STOP Command
switch(topActivityName) {
	case ACTIVITY_NETFLIX_APP:
Log.d(TAG,"force stop NETFLIX app");
stopCmd = FORCE_STOP_NETFLIX;
break;
	case ACTIVITY_NAME_YOUTUBE_TV:
Log.d(TAG,"force stop YOUTUBE TV app");
stopCmd = FORCE_STOP_YOUTUBE_TV;
break;
	case ACTIVITY_DISNEY_APP:
Log.d(TAG,"force stop DISNEY app");
stopCmd = FORCE_STOP_DISNEY;
break;
	default:
Log.d(TAG,"there is no app for force-stop ..!!");
return;
}

mDeviceManagerActivity.systemCmd(stopCmd);
	}                    

@endcode


@code
의도대로라면:

F12(종료키) 눌렀을 때, top 이 넷플릭스일 때만 지금처럼 처리(강제종료 + KEYCODE_TV 전송)하고,
그 외 앱일 때는 KaonGlobalKeyReceiver 에서 아무것도 안 하고 원래 앱으로 F12를 그냥 보내고 싶다

→ 그러면 넷플릭스가 아닐 때 바로 return 해 버리면 됩니다.
(이 브로드캐스트 리시버에서 아무 추가 동작을 안 하면, 입력 시스템 쪽에서 F12는 그대로 포그라운드 앱으로 전달됩니다.)

예를 들어 아래처럼 수정할 수 있습니다.

else if (event.getKeyCode() == KeyEvent.KEYCODE_F12) {
    if (event.getAction() == KeyEvent.ACTION_UP) {

        String topActivityName = getTopActivityName(context);

        // ❶ 넷플릭스가 아니면 아무 처리도 하지 않고 리턴
        if (!topActivityName.equals(ACTIVITY_NETFLIX_APP)) {
            Log.i(TAG, "F12 up: ignore global handling, top=" + topActivityName);
            // 여기서 return 하면 key 이벤트는 각 앱에서 정상적으로 처리됨
            return;
        }

        // ❷ 여기부터는 "top = 넷플릭스" 인 경우에만 동작
        if (!topActivityName.contains("android.tungsten.setupwraith")) {
            keyCode = KeyEvent.KEYCODE_TV;
        }

        Log.i(TAG, "keycode : " + KeyEvent.keyCodeToString(keyCode) + " up");

        // KSYS : to fix Disney+ app blackout when first time launching
        // [K1078-272] workaround to fix issue
        if (KAON_CHK_KEYSKIP_COND) {
            if (isSkipKeyCondition(keyCode)) return;
        }

        // top == NETFLIX 로 확정된 상태이므로 넷플릭스 강제 종료
        stopOTTAppByForce(context);

        // 디즈니 관련 처리는 여기서는 필요 없으므로 제거하거나,
        // 꼭 필요하다면 별도의 분기에서 처리

        if (!topActivityName.equals(ACTIVITY_KRMS_FWUPDATER_APP) &&
            !topActivityName.contains("android.tungsten.setupwraith")) {

            lghv_intent.setPackage(PACKAGE_KEYCODE_APP);
            lghv_intent.setAction(ACTION_KEYCODE_APP);
            lghv_intent.putExtra(EXTRA_KEYCODE_APP, keyCode);

            String networkType = SystemProperties.get(PERSIST_PROPERTY_NETWORK_TYPE,"");
            Log.i(TAG,"NETWORK_TYPE: "+(networkType.equals(NETWORK_TYPE_LGHV)?"LGHV":"LGU+"));
            Log.i(TAG,"SEND_GLOBALKEY: startForegroundService(lghv_intent)");
            context.startForegroundService(lghv_intent);
            Log.i(TAG,"SEND_GLOBALKEY: 'KEYCODE_TV' to helloTv app: top("+topActivityName+")");
        } else {
            Log.i(TAG,"ignore send 'KEYCODE_TV' to helloTv app: top("+topActivityName+")");
        }
    }
}

정리

변경 포인트 핵심:

if (!topActivityName.equals(ACTIVITY_NETFLIX_APP)) {
    return;
}


이 한 줄로 “넷플릭스가 아니면 글로벌 처리 안 함”을 보장.

이렇게 하면:

넷플릭스일 때: 지금까지처럼 강제 종료 + helloTv로 KEYCODE_TV 전송

그 외 앱일 때: KaonGlobalKeyReceiver는 로그만 찍고 아무 동작도 하지 않음 → F12는 해당 앱에서 자유롭게 처리 (또는 무시)

원하면 “디즈니일 때만 updateDisneyLoggedInfo() 는 유지하고 싶다” 이런 식으로 추가 분기도 같이 정리해 줄 수 있어요.
@endcode

