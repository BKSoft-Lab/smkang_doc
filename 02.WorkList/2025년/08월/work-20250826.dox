 #else
    property_set("vendor.hiddenmenu.factoryreset", "1");
    LOGD("SMKANG vendor.hiddenmenu.factoryreset 1");
 #endif
    LOGD("SMKANG sleep 1s start");
    usleep(1 * 1000 * 1000);
    LOGD("SMKANG sleep 1s end");

    system("sync");

    if (android_reboot(ANDROID_RB_RESTART2, 0, "recovery") == -1)
    {
