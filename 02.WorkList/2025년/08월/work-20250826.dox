void StbApi::androidUserDataReset(void)
{
    LOGD("SMKANG androidUserDataReset");
#if 0
    android::AString errorMessage;
    android::sp<android::AMessage> resultMessage = mProxy.command("DeviceManagerService", "doFactoryReset", NULL, NULL);
    if (!resultMessage)
    {
        LOGE("Cannot send commd to module(DeviceManagerService)\n");
    }
#else
    // LGU+의 경우 dropbear(cli) rc 에서 on property 동작으로 --wipe_data 하는 커맨드실행 되도록함.
    // LGHV의 경우 dropbear(cli) 이 없기 때문에 pvsd.rc에서 on property 동작으로 --wipe_data 하는 커맨드실행 되도록함.
 #if defined(__STBAPI_SYSTEM__)
    property_set("sys.hiddenmenu.factoryreset", "1");
