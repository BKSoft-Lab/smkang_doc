PL_CAB_NETWORK_Type_e PLAPIService::pl_cab_getNetworkType_internal()
{
   PL_CAB_NETWORK_Type_e type = ePL_CAB_NETWORK_DSG_TWO_WAY;
   type = (PL_CAB_NETWORK_Type_e)property_get_int32(PROP_PERSIST_CM_NETWORK_TYPE, ePL_CAB_NETWORK_DSG_TWO_WAY);
   return type;
}
