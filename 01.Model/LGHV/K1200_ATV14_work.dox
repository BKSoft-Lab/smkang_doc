# 빌드 방법
@code 
git clone https://bitbucket.kaonmedia.com/scm/aml14/lghv_k1200ua.git
cd lghv_k1200ua/
git checkout LGHV_K1200UA_OTT
./k1200ua_build.sh clean ota userdebug
./k1200ua_build.sh clean ota user
@endcode

# sigining

> [K1200UA_Prodloader_1.0.4.tgz](../data/K1200ua_ATV14/K1200UA_ProdLoader_ATV14_2.0.2.tgz)
@code

HOW TO USE sigining tools for ATV14 -------
 - 2025/10/15 written by LGHV project team, jfet_

[0] Need new tool 'SIX' for ATV14,.. 
 $wget https://bootstrap.pypa.io/pip/2.7/get-pip.py
 $sudo python2 get-pip.py
 $sudo pip2 install six

[1] make signing image with unsigned image
$./ota_gen.sh --file /shared/fwimg/K1200UA-ota-00.43.1820.zip

[2] copy signed FW image to custom folde and name
$cp K1200UA-ota-00.43.1820_signed.zip {TARGET_DIR_FOR_FW}

[*] script needs python version 2.7 
 - if python version is not meet then might be signing process is failed...

  선택       경로              우선순� 상태
------------------------------------------------------------
  0            /usr/bin/python3.8   2         자동 모드
* 1            /usr/bin/python2.7   1         수동 모드
  2            /usr/bin/python3.8   2         수동 모드


@endcode

# Quber 빌드
@code 
Quber packages/middleware  source code 빌드 방법 입니다. 
소스 빌드 하려면 다음의 두개 폴더가 모두 존재 하여야 합니다. 
vendor/quber/packages
vendor/quber/middleware

주석해제
vi vendor/quber/quber.mk
TARGET_BUILD_QUBER_SRC_BUILD := true 

$source build/envsetup.sh;lunch 3
 
◼ Quber middleware / packages

vendor/quber/packages/pvs
m -j$(nproc) pvsd
adb push out/target/product/K1200UA/system/bin/pvsd system/bin/pvsd
 
vendor/quber/packages/StartupService
m -j$(nproc) StartupService
adb push out/target/product/K1200UA/system/priv-app/StartupService/StartupService.apk system/priv-app/StartupService/Startu pService.apk
 
vendor/quber/packages/libdhcp/
m -j$(nproc) libdhcp
adb push out/target/product/K1200UA/system/lib/libdhcp.so system/lib/libdhcp.so
 
StbApi/StbApi.cpp
m -j$(nproc) libstbapi.system libstbapi.vendor
adb push out/target/product/K1200UA/vendor/lib/libstbapi.vendor.so vendor/lib/libstbapi.vendor.so
adb push out/target/product/K1200UA/system/lib/libstbapi.system.so system/lib/libstbapi.system.so

$ adb root
$ adb remount
adb push libstbapi.vendor.so vendor/lib/libstbapi.vendor.so
adb push libstbapi.system.so system/lib/libstbapi.system.so
이미지로 빌드시 
cp out/target/product/K1200UA/vendor/lib/libstbapi.vendor.so vendor/quber/prebuilts/packages/libstbapi/
cp out/target/product/K1200UA/system/lib/libstbapi.system.so vendor/quber/prebuilts/packages/libstbapi/
vendor/quber/packages 재거
vendor/quber/middleware 제거
./k1200ua_build.sh -o
 
 
hiddenmenu/pages/HiddenMenuPage.cpp
m -j$(nproc) hiddenmenu
adb push out/target/product/K1200UA/vendor/bin/hiddenmenu vendor/bin/hiddenmenu
cp out/target/product/K1200UA/vendor/bin/hiddenmenu vendor/quber/prebuilts/packages/hiddenmenu/
Z:\K1200UA\k1200ua\vendor\quber\prebuilts\packages\pvs

 
@endcode


